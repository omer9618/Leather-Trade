@{
    var currentController = ViewContext.RouteData.Values["controller"]?.ToString();
    var currentAction = ViewContext.RouteData.Values["action"]?.ToString();
    var isBuyer = User.IsInRole("Buyer");
}

<style>
    :root {
        --primary-color: #4a6b57;
        --secondary-color: #6c757d;
        --success-color: #28a745;
        --danger-color: #dc3545;
        --warning-color: #ffc107;
        --info-color: #17a2b8;
        --light-color: #f8f9fa;
        --dark-color: #343a40;
        --border-color: #dee2e6;
    }

    .sidebar {
        width: 250px;
        background: white;
        height: 100vh;
        position: fixed;
        top: 0;
        left: 0;
        box-shadow: 2px 0 10px rgba(0,0,0,0.05);
        display: flex;
        flex-direction: column;
        z-index: 1000;
    }

    .sidebar-header {
        padding: 1.5rem;
        border-bottom: 1px solid var(--border-color);
    }

    .sidebar-header h1 {
        color: var(--primary-color);
        font-size: 2.0rem;
        font-weight: 600;
        margin: 0;
        font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;
    }

    .sidebar-menu {
        flex: 1;
        padding: 1rem 0;
        list-style: none;
        margin: 0;
    }

    .sidebar-menu li {
        padding: 0.8rem 1.5rem;
        display: flex;
        align-items: center;
        cursor: pointer;
        color: #555;
        position: relative;
    }

    .sidebar-menu li i {
        margin-right: 0.8rem;
        width: 20px;
        text-align: center;
    }

    .sidebar-menu li.active {
        background: var(--light-color);
        color: var(--primary-color);
        border-left: 3px solid var(--primary-color);
    }

    .sidebar-menu li a {
        text-decoration: none;
        color: inherit;
        display: flex;
        align-items: center;
        width: 100%;
    }

    .sidebar-menu li:hover {
        background: var(--light-color);
    }

    .sidebar-footer {
        padding: 1.5rem;
        border-top: 1px solid var(--border-color);
    }

    .logout-btn {
        color: #555;
        text-decoration: none;
        display: flex;
        align-items: center;
        background: none;
        border: none;
        cursor: pointer;
        width: 100%;
        text-align: left;
        font-size: 1rem;
    }

    .logout-btn i {
        margin-right: 0.8rem;
    }

    .logout-btn:hover {
        color: var(--primary-color);
    }

    .toggle-sidebar {
        display: none !important;
    }

    .sidebar-toggle-btn {
        display: none !important;
    }
</style>

<div class="sidebar" id="sidebar">
    <div class="sidebar-header" style="display: flex; align-items: center;">
        <h1 style="margin: 0; font-size: 1.7rem; color: var(--primary-color); font-weight: 600;">Leathrix</h1>
    </div>
    <ul class="sidebar-menu">
        @if (isBuyer)
        {
            <li class="@(currentController == "Buyer" && currentAction == "Dashboard" ? "active" : "")">
                <a asp-controller="Buyer" asp-action="Dashboard">
                    <i class="fas fa-home"></i> Dashboard
                </a>
            </li>
            <li class="@(currentController == "Buyer" && currentAction == "CreateDemand" ? "active" : "")">
                <a asp-controller="Buyer" asp-action="CreateDemand">
                    <i class="fas fa-plus-square"></i> Create Demand
                </a>
            </li>
            <li class="@(currentController == "Order" ? "active" : "")">
                <a asp-controller="Order" asp-action="Index">
                    <i class="fas fa-shopping-cart"></i> Orders
                </a>
            </li>
            <li class="@(currentController == "Payment" ? "active" : "")">
                <a asp-controller="Payment" asp-action="History">
                    <i class="fas fa-credit-card"></i> Payment History
                </a>
            </li>
        }
        else
        {
            <li class="@(currentController == "Seller" && currentAction == "Dashboard" ? "active" : "")">
                <a asp-controller="Seller" asp-action="Dashboard">
                    <i class="fas fa-tachometer-alt"></i> Dashboard
                </a>
            </li>
            <li class="@(currentController == "Seller" && currentAction == "Demands" ? "active" : "")">
                <a asp-controller="Seller" asp-action="Demands">
                    <i class="fas fa-list"></i> All Demands
                </a>
            </li>
            <li class="@(currentController == "Seller" && currentAction == "MyBids" ? "active" : "")">
                <a asp-controller="Seller" asp-action="MyBids">
                    <i class="fas fa-gavel"></i> My Bids
                </a>
            </li>
            <li class="@(currentController == "Seller" && currentAction == "Orders" ? "active" : "")">
                <a asp-controller="Seller" asp-action="Orders">
                    <i class="fas fa-shopping-cart"></i> My Orders
                </a>
            </li>
            <li class="@(currentController == "Inventory" ? "active" : "")">
                <a asp-controller="Inventory" asp-action="Index">
                    <i class="fas fa-box"></i> Inventory
                </a>
            </li>
        }
      
        <li class="nav-item">
            <a class="nav-link" href="/AIChat/Chatbot">
                <i class="fas fa-robot"></i> AI Chatbot
            </a>
        </li>
        <li class="nav-item">
            <a class="nav-link" href="/Account/Profile">
                <i class="fas fa-user"></i> Profile
            </a>
        </li>
    </ul>
    <div class="sidebar-footer">
        <form asp-controller="Account" asp-action="Logout" method="post" id="logoutForm">
            @Html.AntiForgeryToken()
            <button type="submit" class="logout-btn">
                <i class="fas fa-sign-out-alt"></i> Logout
            </button>
        </form>
    </div>
</div>

<script>
    document.addEventListener('DOMContentLoaded', function() {
        // Empty - no toggle functionality
    });
</script> 