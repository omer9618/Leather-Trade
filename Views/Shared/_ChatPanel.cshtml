@* Shared Chat Panel Partial View *@
@{
    var currentUserId = User.FindFirst(System.Security.Claims.ClaimTypes.NameIdentifier)?.Value;
}

<div class="modal" id="chatModal" tabindex="-1" style="display:none; position:fixed; top:0; left:0; width:100vw; height:100vh; background:rgba(0,0,0,0.08); z-index:9999; align-items:center; justify-content:center;">
    <div class="modal-dialog" style="max-width:500px; width:500px; margin:auto; height:90vh; display:flex; flex-direction:column; flex:1;">
        <div class="modal-content" style="height:100%; display:flex; flex-direction:column; flex:1;">
            <div class="modal-header" style="flex-shrink:0;">
                <h5 class="modal-title">Chat with <span id="chatUserName"></span></h5>
                <button type="button" class="close" style="z-index:10001; position:relative;" onclick="closeChatModal()">&times;</button>
            </div>
            <div class="modal-body" id="chatMessages" style="flex:1 1 0; overflow-y:scroll !important; overflow-x:hidden; display:flex; flex-direction:column; gap:6px; background:transparent; padding:1rem; min-height:120px; max-height:unset;">
                <!-- Chat messages will be dynamically added here -->
            </div>
            <div class="modal-footer" style="flex-shrink:0; padding: 0 1rem 0.5rem 1rem; background: transparent; border-top: none; border-radius: 0 0 24px 24px; min-height:unset; height:auto; margin-bottom:0;">
                <div class="input-row" style="margin-bottom:0; padding-bottom:0;">
                    <input type="text" id="chatInput" class="form-control" placeholder="Type a message..." />
                    <button class="btn btn-primary" onclick="sendChatMessage()">
                        <i class="fas fa-paper-plane"></i>
                    </button>
                </div>
            </div>
        </div>
    </div>
</div>

<style>
:root {
    --primary-green: #4a6b57;
    --primary-green-light: #eaf6f0;
}

#chatModal {
    z-index: 9999 !important;
    display: flex;
    align-items: center;
    justify-content: center;
    height: 100vh !important;
}

#chatModal .modal-dialog {
    max-width: 500px;
    width: 500px;
    height: 90vh;
    display: flex;
    flex-direction: column;
    flex: 1 1 auto;
}

#chatModal .modal-content {
    height: 100%;
    display: flex;
    flex-direction: column;
    border-radius: 24px;
    box-shadow: 0 8px 32px rgba(0,0,0,0.13);
    background: #fff;
    border: none;
    padding: 0;
    font-family: 'Segoe UI', sans-serif;
    margin: auto;
    width: 100%;
    flex: 1 1 auto;
}

#chatModal .modal-header {
    flex-shrink: 0;
    background: transparent;
    border-bottom: none;
    border-radius: 24px 24px 0 0;
    padding: 2rem 2rem 0.5rem 2rem;
    display: flex;
    flex-direction: row;
    align-items: flex-start;
    justify-content: space-between;
}

#chatModal .modal-title {
    color: var(--primary-green);
    font-weight: 800;
    font-size: 1.3rem;
    margin-bottom: 0.2rem;
}

#chatModal .close {
    background: none;
    border: none;
    font-size: 1.5rem;
    color: var(--primary-green);
    cursor: pointer;
    margin-left: 1rem;
    margin-top: -0.5rem;
    z-index: 10001;
    position: relative;
}

#chatModal .modal-body {
    flex: 1 1 0;
    overflow-y: scroll !important;
    overflow-x: hidden;
    display: flex;
    flex-direction: column;
    gap: 6px;
    background: transparent;
    padding: 1rem;
    min-height: 120px;
    max-height: unset;
}

#chatModal .chat-bubble {
    display: block;
    padding: 10px 18px;
    border-radius: 16px;
    font-size: 1rem;
    font-weight: 500;
    max-width: 80%;
    word-break: break-word;
    box-shadow: 0 1px 6px rgba(0,0,0,0.06);
}

#chatModal .chat-bubble.me {
    background: var(--primary-green) !important;
    color: #fff !important;
    align-self: flex-end;
}

#chatModal .chat-bubble.them {
    background: var(--primary-green-light) !important;
    color: var(--primary-green) !important;
    align-self: flex-start;
}

#chatModal .modal-footer {
    flex-shrink: 0;
    background: transparent;
    border-top: none;
    border-radius: 0 0 24px 24px;
    padding: 0 1rem 0.5rem 1rem !important;
    display: flex;
    flex-direction: column;
    align-items: stretch;
    min-height: unset;
    height: auto;
    margin-bottom: 0 !important;
}

#chatModal .input-row {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    margin-bottom: 0 !important;
    padding-bottom: 0 !important;
}

#chatModal .form-control {
    border-radius: 18px;
    border: none;
    background: #f8f9fa;
    font-size: 1rem;
    padding: 0.8rem 1.2rem;
    flex: 1;
    outline: none;
    box-shadow: none;
}

#chatModal .btn-primary {
    background: var(--primary-green) !important;
    color: #fff !important;
    border-radius: 50% !important;
    width: 44px;
    height: 44px;
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 1.3rem;
    font-weight: 600;
    transition: background 0.2s;
    box-shadow: 0 2px 8px rgba(0,0,0,0.07);
    border: none;
    padding: 0;
}

#chatModal .btn-primary:hover {
    background: #3a5a47 !important;
}

#chatMessages {
    overflow-y: scroll !important;
    min-height: 120px;
    scrollbar-width: auto;
    scrollbar-color: #4a6b57 #eaf6f0;
}

#chatMessages::-webkit-scrollbar {
    width: 10px;
}

#chatMessages::-webkit-scrollbar-thumb {
    background: #4a6b57;
    border-radius: 8px;
}

#chatMessages::-webkit-scrollbar-track {
    background: #eaf6f0;
    border-radius: 8px;
}
</style>

<script>
let chatConnection = null;
let currentBidId = null;
let currentBuyerId = null;
let currentBuyerName = null;
let currentUserId = '@User.FindFirst(System.Security.Claims.ClaimTypes.NameIdentifier)?.Value';

window.openChatModal = function(bidId, buyerId, buyerName) {
    currentBidId = bidId;
    currentBuyerId = buyerId;
    currentBuyerName = buyerName;
    document.getElementById('chatUserName').textContent = buyerName;
    document.getElementById('chatModal').style.display = 'flex';
    document.getElementById('chatMessages').innerHTML = '<div class="text-center text-muted">Loading...</div>';
    document.getElementById('chatInput').value = '';
    loadChatHistory();
    startSignalR(bidId);
}
window.closeChatModal = function() {
    document.getElementById('chatModal').style.display = 'none';
    if (chatConnection) chatConnection.stop();
}
function loadChatHistory() {
    fetch(`/api/Chat/GetBidChat?bidId=${currentBidId}`)
        .then(res => res.json())
        .then(messages => {
            const chatBox = document.getElementById('chatMessages');
            chatBox.innerHTML = '';
            if (messages.length === 0) {
                chatBox.innerHTML = '<div class="text-center text-muted">No messages yet.</div>';
            } else {
                messages.forEach(msg => {
                    appendChatBubble(msg.senderId, msg.message);
                });
                chatBox.scrollTop = chatBox.scrollHeight;
            }
        });
}
function startSignalR(bidId) {
    if (chatConnection) chatConnection.stop();
    chatConnection = new signalR.HubConnectionBuilder().withUrl('/chathub').build();
    chatConnection.start().then(() => {
        chatConnection.invoke('JoinGroup', `bid-${bidId}`);
    });
    chatConnection.on('ReceiveMessage', (senderId, receiverId, message) => {
        if ((senderId === currentUserId && receiverId === currentBuyerId) || (senderId === currentBuyerId && receiverId === currentUserId)) {
            loadChatHistory();
        }
    });
}
window.sendChatMessage = function() {
    const input = document.getElementById('chatInput');
    const message = input.value.trim();
    if (!message) return;
    appendChatBubble(currentUserId, message);
    input.value = '';
    chatConnection.invoke('SendMessage', `bid-${currentBidId}`, currentUserId, currentBuyerId, message);
    fetch('/api/Chat/SendBidMessage', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ bidId: currentBidId, senderId: currentUserId, receiverId: currentBuyerId, message })
    }).then(() => {
        loadChatHistory();
    });
}
function appendChatBubble(senderId, message) {
    const chatBox = document.getElementById('chatMessages');
    const isMe = senderId === currentUserId;
    const bubbleClass = isMe ? 'chat-bubble me' : 'chat-bubble them';
    chatBox.innerHTML += `<div class="${bubbleClass}">${isMe ? 'You: ' : ''}${message}</div>`;
    chatBox.scrollTop = chatBox.scrollHeight;
}
window.onclick = function(event) {
    const modal = document.getElementById('chatModal');
    if (event.target == modal) window.closeChatModal();
}
</script> 