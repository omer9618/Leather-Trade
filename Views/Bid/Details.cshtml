@model LTMS.Models.Bid

<div class="container mt-4">
    <div class="row">
        <div class="col-md-8 offset-md-2">
            <div class="card">
                <div class="card-header">
                    <h3>Bid Details</h3>
                </div>
                <div class="card-body">
                    <div class="row mb-3">
                        <div class="col-md-4">
                            <strong>Amount:</strong>
                        </div>
                        <div class="col-md-8">
                            $@Model.Amount.ToString("N2")
                        </div>
                    </div>
                    <div class="row mb-3">
                        <div class="col-md-4">
                            <strong>Description:</strong>
                        </div>
                        <div class="col-md-8">
                            @Model.Description
                        </div>
                    </div>
                    <div class="row mb-3">
                        <div class="col-md-4">
                            <strong>Delivery Time:</strong>
                        </div>
                        <div class="col-md-8">
                            @Model.DeliveryTime days
                        </div>
                    </div>
                    <div class="row mb-3">
                        <div class="col-md-4">
                            <strong>Status:</strong>
                        </div>
                        <div class="col-md-8">
                            @Model.Status
                        </div>
                    </div>

                    @if (Model.Status == "Accepted")
                    {
                        <div class="text-center mt-4">
                            <button type="button" class="btn btn-primary" onclick="openPaymentModal(@Model.Amount, @Model.Id)">
                                Pay Now
                            </button>
                        </div>
                    }
                </div>
            </div>
        </div>
    </div>
</div>

@await Html.PartialAsync("_PaymentModal")

@section Scripts {
    <script src="~/js/payment.js"></script>
} 