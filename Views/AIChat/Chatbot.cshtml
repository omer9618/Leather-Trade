<!-- AI Chat Button -->
<button id="aiChatToggle" class="ai-chat-toggle" onclick="toggleAIChatModal()">
    <i class="fas fa-robot"></i>
    <span>AI Assistant</span>
</button>

<!-- AI Chat Modal -->
<div class="modal" id="aiChatModal" tabindex="-1" style="display:none;">
    <div class="modal-dialog">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title">AI Assistant</h5>
                <button type="button" class="close" onclick="closeAIChatModal()">&times;</button>
            </div>
            <div class="modal-body" id="aiChatMessages">
                <div class="chat-bubble them">
                    <div class="chat-header">
                        <span class="chat-sender">AI Assistant</span>
                        <span class="chat-time">Just now</span>
                    </div>
                    <div class="chat-text">Hello! How can I assist you today?</div>
                </div>
            </div>
            <div class="modal-footer">
                <div class="input-row">
                    <input type="text" id="aiChatInput" class="form-control" placeholder="Type your message..." />
                    <button class="btn btn-send" onclick="sendAIChatMessage()">
                        <i class="fas fa-paper-plane"></i>
                    </button>
                </div>
            </div>
        </div>
    </div>
</div>

<style>
    :root {
        --primary-green: #4a6b57;
        --primary-green-light: #eaf6f0;
        --primary-green-dark: #3a5a47;
    }

    /* Chat Toggle Button */
    .ai-chat-toggle {
        position: fixed;
        bottom: 25px;
        right: 25px;
        background: var(--primary-green);
        color: white;
        border: none;
        padding: 12px 20px 12px 16px;
        border-radius: 25px;
        cursor: pointer;
        z-index: 10000;
        display: flex;
        align-items: center;
        gap: 10px;
        font-size: 16px;
        font-weight: 600;
        box-shadow: 0 4px 12px rgba(74, 107, 87, 0.25);
        transition: all 0.2s ease;
        font-family: 'Segoe UI', sans-serif;
    }

        .ai-chat-toggle:hover {
            background: var(--primary-green-dark);
            transform: translateY(-2px);
            box-shadow: 0 6px 16px rgba(74, 107, 87, 0.3);
        }

        .ai-chat-toggle i {
            font-size: 18px;
        }

    /* Modal Structure */
    #aiChatModal {
        z-index: 9999 !important;
        display: none;
        position: fixed;
        top: 0;
        left: 0;
        width: 100vw;
        height: 100vh;
        background: rgba(0,0,0,0.08);
        align-items: center;
        justify-content: center;
        font-family: 'Segoe UI', sans-serif;
    }

        #aiChatModal .modal-dialog {
            max-width: 500px;
            width: 500px;
            height: 90vh;
            display: flex;
            flex-direction: column;
            flex: 1 1 auto;
        }

        #aiChatModal .modal-content {
            height: 100%;
            display: flex;
            flex-direction: column;
            border-radius: 24px;
            box-shadow: 0 8px 32px rgba(0,0,0,0.13);
            background: #fff;
            border: none;
            padding: 0;
            margin: auto;
            width: 100%;
            flex: 1 1 auto;
        }

        /* Header */
        #aiChatModal .modal-header {
            flex-shrink: 0;
            background: transparent;
            border-bottom: none;
            border-radius: 24px 24px 0 0;
            padding: 1.5rem 1.5rem 0.5rem 1.5rem;
            display: flex;
            flex-direction: row;
            align-items: flex-start;
            justify-content: space-between;
        }

        #aiChatModal .modal-title {
            color: var(--primary-green);
            font-weight: 800;
            font-size: 1.25rem;
            margin-bottom: 0;
        }

        #aiChatModal .close {
            background: none;
            border: none;
            font-size: 1.75rem;
            color: var(--primary-green);
            cursor: pointer;
            margin-left: 1rem;
            margin-top: -0.5rem;
            opacity: 0.8;
            transition: opacity 0.2s;
            padding: 0;
            line-height: 1;
        }

            #aiChatModal .close:hover {
                opacity: 1;
            }

        /* Chat Messages Area */
        #aiChatModal .modal-body {
            flex: 1 1 0;
            overflow-y: scroll !important;
            overflow-x: hidden;
            display: flex;
            flex-direction: column;
            gap: 12px;
            background: transparent;
            padding: 1.5rem;
            min-height: 120px;
            max-height: unset;
        }

    /* Message Bubbles */
    .chat-bubble {
        display: flex;
        flex-direction: column;
        padding: 12px 16px;
        border-radius: 16px;
        font-size: 0.95rem;
        max-width: 82%;
        word-break: break-word;
        box-shadow: 0 1px 6px rgba(0,0,0,0.06);
        line-height: 1.4;
    }

        .chat-bubble.me {
            background: var(--primary-green);
            color: #fff;
            align-self: flex-end;
            border-bottom-right-radius: 4px;
        }

        .chat-bubble.them {
            background: var(--primary-green-light);
            color: var(--primary-green);
            align-self: flex-start;
            border-bottom-left-radius: 4px;
        }

    .chat-header {
        display: flex;
        justify-content: space-between;
        align-items: center;
        margin-bottom: 4px;
        font-size: 0.8rem;
    }

    .chat-sender {
        font-weight: 700;
    }

    .chat-time {
        opacity: 0.7;
        margin-left: 10px;
    }

    .chat-bubble.me .chat-time {
        color: rgba(255,255,255,0.8);
    }

    .chat-bubble.them .chat-time {
        color: rgba(74, 107, 87, 0.7);
    }

    /* Input Area */
    #aiChatModal .modal-footer {
        flex-shrink: 0;
        background: transparent;
        border-top: none;
        border-radius: 0 0 24px 24px;
        padding: 0 1.5rem 1.5rem 1.5rem !important;
        display: flex;
        flex-direction: column;
        align-items: stretch;
        min-height: unset;
        height: auto;
        margin-bottom: 0 !important;
    }

    #aiChatModal .input-row {
        display: flex;
        align-items: center;
        gap: 0.75rem;
        margin-bottom: 0 !important;
        padding-bottom: 0 !important;
    }

    #aiChatModal .form-control {
        border-radius: 18px;
        border: 1px solid #e0e0e0;
        background: #f8f9fa;
        font-size: 0.95rem;
        padding: 0.75rem 1.25rem;
        flex: 1;
        outline: none;
        box-shadow: none;
        transition: all 0.2s;
        font-family: 'Segoe UI', sans-serif;
    }

        #aiChatModal .form-control:focus {
            border-color: var(--primary-green);
            box-shadow: 0 0 0 2px rgba(74, 107, 87, 0.2);
        }

    #aiChatModal .btn-send {
        background: var(--primary-green) !important;
        color: #fff !important;
        border-radius: 50% !important;
        width: 44px;
        height: 44px;
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 1.1rem;
        transition: all 0.2s;
        box-shadow: 0 2px 8px rgba(74, 107, 87, 0.2);
        border: none;
        padding: 0;
    }

        #aiChatModal .btn-send:hover {
            background: var(--primary-green-dark) !important;
            transform: translateY(-1px);
        }

        #aiChatModal .btn-send:active {
            transform: translateY(0);
        }

    /* Scrollbar */
    #aiChatMessages {
        scrollbar-width: thin;
        scrollbar-color: var(--primary-green) var(--primary-green-light);
    }

        #aiChatMessages::-webkit-scrollbar {
            width: 8px;
        }

        #aiChatMessages::-webkit-scrollbar-thumb {
            background: var(--primary-green);
            border-radius: 4px;
        }

        #aiChatMessages::-webkit-scrollbar-track {
            background: var(--primary-green-light);
            border-radius: 4px;
        }
</style>

<script>
    // Toggle Functions
    function toggleAIChatModal() {
        const modal = document.getElementById('aiChatModal');
        if (modal.style.display === 'flex') {
            closeAIChatModal();
        } else {
            openAIChatModal();
        }
    }

    function openAIChatModal() {
        const modal = document.getElementById('aiChatModal');
        modal.style.display = 'flex';
        document.getElementById('aiChatInput').focus();
    }

    function closeAIChatModal() {
        const modal = document.getElementById('aiChatModal');
        modal.style.display = 'none';
    }

    // Message Functions
    function sendAIChatMessage() {
        const input = document.getElementById('aiChatInput');
        const message = input.value.trim();

        if (message) {
            addAIChatMessage(message, 'me');
            input.value = '';

            // Simulate AI typing indicator
            const typingIndicator = addTypingIndicator();

            // Simulate delayed AI response
            setTimeout(() => {
                removeTypingIndicator(typingIndicator);
                addAIChatMessage(getAIResponse(message), 'them');
            }, 1000 + Math.random() * 1500);
        }
    }

    function addAIChatMessage(text, sender) {
        const messagesContainer = document.getElementById('aiChatMessages');
        const messageElement = document.createElement('div');
        messageElement.className = `chat-bubble ${sender}`;

        const now = new Date();
        const timeString = now.toLocaleTimeString([], { hour: '2-digit', minute: '2-digit' });

        messageElement.innerHTML = `
            <div class="chat-header">
                <span class="chat-sender">${sender === 'me' ? 'You' : 'AI Assistant'}</span>
                <span class="chat-time">${timeString}</span>
            </div>
            <div class="chat-text">${text}</div>
        `;

        messagesContainer.appendChild(messageElement);
        messagesContainer.scrollTop = messagesContainer.scrollHeight;
    }

    function addTypingIndicator() {
        const messagesContainer = document.getElementById('aiChatMessages');
        const indicator = document.createElement('div');
        indicator.className = 'chat-bubble them typing-indicator';
        indicator.innerHTML = `
            <div class="chat-header">
                <span class="chat-sender">AI Assistant</span>
            </div>
            <div class="chat-text typing-dots">
                <span>•</span><span>•</span><span>•</span>
            </div>
        `;
        messagesContainer.appendChild(indicator);
        messagesContainer.scrollTop = messagesContainer.scrollHeight;
        return indicator;
    }

    function removeTypingIndicator(indicator) {
        if (indicator && indicator.parentNode) {
            indicator.parentNode.removeChild(indicator);
        }
    }

    function getAIResponse(message) {
        // This would be replaced with actual AI API calls
        const responses = [
            "I understand you're asking about: " + message,
            "Thanks for your message. Let me help with that.",
            "I can provide information about that topic.",
            "That's an interesting question. Here's what I know...",
            "I'm designed to assist with queries like this."
        ];
        return responses[Math.floor(Math.random() * responses.length)];
    }

    // Event Listeners
    document.getElementById('aiChatInput').addEventListener('keypress', function (e) {
        if (e.key === 'Enter') {
            sendAIChatMessage();
        }
    });

    document.getElementById('aiChatModal').addEventListener('click', function (e) {
        if (e.target === this) {
            closeAIChatModal();
        }
    });

    // Typing Indicator Animation
    const style = document.createElement('style');
    style.textContent = `
    @@keyframes typingPulse {
        0%, 100% { opacity: 0.4; }
        50% { opacity: 1; }
    }

    .typing-dots span {
        animation: typingPulse 1.4s infinite ease-in-out;
        display: inline-block;
        margin: 0 1px;
    }

    .typing-dots span:nth-child(2) {
        animation-delay: 0.2s;
    }

    .typing-dots span:nth-child(3) {
        animation-delay: 0.4s;
    }
    `;
    document.head.appendChild(style);
</script>